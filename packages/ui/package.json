{
  "name": "@fundi/ui",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./styles.css": "./src/styles.css",
    "./tokens/*": "./src/tokens/*"
  },
  "scripts": {
    "build": "node -e \"console.log('[@fundi/ui] no-op build')\"",
    "lint": "eslint . --max-warnings=0",
    "test": "node --test \"src/**/*.test.ts\"",
    "dev": "node -e \"console.log('[@fundi/ui] no-op dev')\"",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@fundi/types": "workspace:*"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@fundi/config": "workspace:*",
    "@storybook/nextjs": "10.5.0",
    "@storybook/addon-docs": "10.5.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "eslint": "10.7.0",
    "next": "16.2.10",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "storybook": "10.5.0",
    "typescript": "6.0.3"
  }
}
