# Copy this file to `.env` (same directory) and adjust if needed:
#   cp apps/api/.env.example apps/api/.env
#
# The defaults below match the services in the repo-root docker-compose.yml,
# so after `docker compose up -d` the API connects with zero further config.
# `.env` is gitignored — never commit real credentials.

# Postgres — used by Prisma (ADR-006, ADR-008).
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://fundi:fundi@localhost:5432/fundi?schema=public"

# DIRECT_URL — a non-pooled connection used only by `prisma migrate`. Locally it
# can equal DATABASE_URL (docker-compose Postgres isn't pooled). In production
# (Supabase + Render, see render.yaml): DATABASE_URL = transaction pooler (:6543,
# ?pgbouncer=true), DIRECT_URL = session pooler (:5432). Both use the IPv4
# `…pooler.supabase.com` host — Render can't reach Supabase's IPv6 direct host.
DIRECT_URL="postgresql://fundi:fundi@localhost:5432/fundi?schema=public"

# CORS_ORIGINS — comma-separated browser origins allowed to call the API
# (creator/learner PWAs). Leave unset locally to allow all; set explicitly in prod.
# CORS_ORIGINS="http://localhost:3001,http://localhost:3002"

# Redis — used by BullMQ for drip/scheduling jobs (ADR-009). Not used yet
# (scheduling is a stub); provision a Redis and set this when that work lands.
REDIS_URL="redis://localhost:6379"

# --- OTP delivery (feature 0009) --------------------------------------------
# How OTP codes physically reach a user. Leave as `stub` for local dev and CI —
# the stub logs codes and never touches the network. Set to `sms` to send real
# SMS via the configured provider. All values are server-side only.
OTP_DELIVERY_DRIVER="stub"          # stub (default) | sms
SMS_PROVIDER="vynfy"                # active provider when driver=sms (known: vynfy)
SMS_SENDER_ID="Fundi"               # ≤11 chars; MUST be registered + approved with the provider
# Optional — {code} and {minutes} are filled at send time; keep it ≤160 chars.
# OTP_MESSAGE_TEMPLATE="Your Fundi code is {code}. It expires in {minutes} min. Never share it."

# --- Vynfy SMS (read only when SMS_PROVIDER=vynfy) --------------------------
# API docs: https://sms.vynfy.com/api/v1/docs — auth is the `X-API-Key` header.
VYNFY_API_KEY=""                    # secret — never commit a real value
VYNFY_BASE_URL="https://sms.vynfy.com"
VYNFY_SANDBOX="false"               # true → sandbox path (accepted but NOT delivered)

# --- Device trust + PIN step-up (feature 0010) ------------------------------
# Server-side only (per env policy — never NEXT_PUBLIC). The re-auth clocks
# (REFRESH_IDLE_TIMEOUT_SECONDS / REFRESH_ABSOLUTE_TTL_SECONDS) and PIN policy
# (length/attempts/backoff) are compile-time defaults in auth.constants.ts and
# are NOT read from env; only the secrets/ceilings below are env-tunable.
#
# PIN_PEPPER — HMAC key applied over the scrypt PIN hash, held OUTSIDE the DB so
# a DB-only leak yields nothing crackable offline. Leave unset for local dev/CI
# (an insecure dev fallback is used); production MUST set it or PIN hashing is
# refused loudly.
PIN_PEPPER=""                       # secret — never commit a real value
#
# SMS_DAILY_BUDGET — org-wide daily SMS ceiling (global circuit-breaker). Unset
# or non-positive → breaker OFF (no ceiling). Set a positive integer in prod to
# fail-closed + alert once the day's enrollment + forgot-PIN sends hit the cap.
# SMS_DAILY_BUDGET="500"
#
# AUTH_COOKIE_SAMESITE is fixed to `strict` in auth.constants.ts (not env-read).
