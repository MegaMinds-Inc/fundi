# Copy this file to `.env` (same directory) and adjust if needed:
#   cp apps/api/.env.example apps/api/.env
#
# The defaults below match the services in the repo-root docker-compose.yml,
# so after `docker compose up -d` the API connects with zero further config.
# `.env` is gitignored — never commit real credentials.

# Postgres — used by Prisma (ADR-006, ADR-008).
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://fundi:fundi@localhost:5432/fundi?schema=public"

# DIRECT_URL — a non-pooled connection used only by `prisma migrate`. Locally it
# can equal DATABASE_URL (docker-compose Postgres isn't pooled). In production
# (Supabase + Render, see render.yaml): DATABASE_URL = transaction pooler (:6543,
# ?pgbouncer=true), DIRECT_URL = session pooler (:5432). Both use the IPv4
# `…pooler.supabase.com` host — Render can't reach Supabase's IPv6 direct host.
DIRECT_URL="postgresql://fundi:fundi@localhost:5432/fundi?schema=public"

# CORS_ORIGINS — comma-separated browser origins allowed to call the API
# (creator/learner PWAs). Leave unset locally to allow all; set explicitly in prod.
# CORS_ORIGINS="http://localhost:3001,http://localhost:3002"

# Redis — used by BullMQ for drip/scheduling jobs (ADR-009). Not used yet
# (scheduling is a stub); provision a Redis and set this when that work lands.
REDIS_URL="redis://localhost:6379"
