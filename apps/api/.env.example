# Copy this file to `.env` (same directory) and adjust if needed:
#   cp apps/api/.env.example apps/api/.env
#
# The defaults below match the services in the repo-root docker-compose.yml,
# so after `docker compose up -d` the API connects with zero further config.
# `.env` is gitignored — never commit real credentials.

# Postgres — used by Prisma (ADR-006, ADR-008).
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://fundi:fundi@localhost:5432/fundi?schema=public"

# Redis — used by BullMQ for drip/scheduling jobs (ADR-009).
REDIS_URL="redis://localhost:6379"
